# Translator2k build-time secrets.
#
# Copy this file to `.env` (gitignored) and fill in real values before
# `npm run build`. The bundled AI backends (gemma / qwen / hy3) read their
# endpoint + API key from these vars at build time; the values are inlined
# into the bundled `dist/` output. NEVER commit `.env`.
#
# Rotate any key that was previously committed to git history.

VITE_GEMMA_ENDPOINT=https://your-gemma-endpoint.example/v1
VITE_GEMMA_API_KEY=
VITE_GEMMA_MODEL=gemma-4-31b-it

VITE_QWEN_ENDPOINT=https://your-qwen-endpoint.example/v1
VITE_QWEN_API_KEY=
VITE_QWEN_MODEL=qwen

VITE_HY3_ENDPOINT=https://your-hy3-endpoint.example/v1
VITE_HY3_API_KEY=
VITE_HY3_MODEL=hy3-preview