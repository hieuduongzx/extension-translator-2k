# Translator2k build-time secrets.
#
# Copy this file to `.env` (gitignored) and fill in real values before
# `npm run build`. Built-in AI backends share one OpenAI-compatible gateway;
# the gateway routes by model id. Values are inlined into `dist/`.
# NEVER commit `.env`.

# Shared gateway
VITE_AI_ENDPOINT=http://103.38.236.38:20128/v1
VITE_AI_API_KEY=

# Built-in model ids (gateway routes)
VITE_MISTRAL_MODEL=mistral/mistral-small-2603
VITE_GPT_OSS_MODEL=groq/openai/gpt-oss-120b
