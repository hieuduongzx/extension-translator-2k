# Translator2k build-time secrets.
#
# Copy this file to `.env` (gitignored) and fill in real values before
# `npm run build`. The bundled AI backend (gemma) reads its endpoint + API key
# from these vars at build time; the values are inlined into the bundled
# `dist/` output. NEVER commit `.env`.
#
# Rotate any key that was previously committed to git history.

VITE_GEMMA_ENDPOINT=https://your-gemma-endpoint.example/v1
VITE_GEMMA_API_KEY=
VITE_GEMMA_MODEL=gemma-4-31b-it
